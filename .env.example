# Copie para .env e preencha — nunca commite o .env

# PostgreSQL
POSTGRES_DB=farmacia_monitor
POSTGRES_USER=farmacia
POSTGRES_PASSWORD=farmacia123

# SQLAlchemy usa esta URL (gerada automaticamente pelo docker-compose)
DATABASE_URL=postgresql://farmacia:farmacia123@localhost:5432/farmacia_monitor

# Scraper
HEADLESS=true
PARALELO_MAX=5
TIMEOUT_MS=30000
